# Configuration locale sans Docker — copiez en .env.local
# copy .env.local.example .env.local

# MariaDB (local ou Minestrator — voir DEPLOY.md)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=minecraft_admin
DB_USER=admin
DB_PASSWORD=adminpassword

# Panel (8080 souvent pris par AirPlay sur Windows — utilisez 8081 si conflit)
SERVER_PORT=8081
CORS_ORIGINS=http://localhost:8081

# Sécurité — alignez avec plugins/AdminPlugin/config.yml
JWT_SECRET=change-me-generate-a-long-random-secret-key-for-jwt-signing
IP_HASH_SALT=change-me-in-production
IP_ENCRYPTION_KEY=change-me-32-chars-minimum-key!!
