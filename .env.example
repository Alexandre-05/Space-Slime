# Panel Docker + MariaDB Minestrator (externe)
# cp .env.example .env   (Linux)  |  copy .env.example .env   (Windows)

# Panel
PANEL_PORT=8080
# Accueil : http://IP:8080/ | Panel : http://IP:8080/dashboard/
# 0.0.0.0 = accès direct (Hostinger) | 127.0.0.1 = derrière Nginx uniquement
PANEL_BIND=0.0.0.0

# MariaDB Minestrator (identique au plugin AdminPlugin/config.yml)
DB_HOST=sql4.minestrator.com
DB_PORT=3306
DB_NAME=minesr_XXXXX
DB_USER=minesr_XXXXX
DB_PASSWORD=change-me

# Sécurité — DOIT être identique dans plugins/AdminPlugin/config.yml
JWT_SECRET=change-me-generate-at-least-64-random-characters-here-for-jwt-signing
IP_HASH_SALT=change-me-in-production
IP_ENCRYPTION_KEY=change-me-32-chars-minimum-key!!

# URL publique du panel (avec https:// si Nginx + Certbot)
CORS_ORIGINS=https://admin.monserveur.fr
