# Copiez ce fichier en .env et modifiez les valeurs avant le déploiement
# cp .env.example .env   (Linux)  |  copy .env.example .env   (Windows)

# Port du panel web — accueil http://localhost:8080/ | panel http://localhost:8080/dashboard/
PANEL_PORT=8080

# MariaDB
DB_NAME=minecraft_admin
DB_USER=admin
DB_PASSWORD=change-me-strong-password
DB_PORT=3306
MARIADB_ROOT_PASSWORD=change-me-root-password

# Sécurité — DOIT être identique dans le plugin Minecraft (config.yml)
JWT_SECRET=change-me-generate-at-least-64-random-characters-here-for-jwt-signing
IP_HASH_SALT=change-me-in-production
IP_ENCRYPTION_KEY=change-me-32-chars-minimum-key!!

# URL publique du panel (ex. https://admin.monserveur.fr ou http://192.168.1.10:8080)
CORS_ORIGINS=http://localhost:8080
